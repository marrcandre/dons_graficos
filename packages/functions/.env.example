# Variáveis de ambiente das Edge Functions (Supabase Secrets)
# Configure via: supabase secrets set NOME=valor
# Ou em: https://app.supabase.com → Edge Functions → Secrets

SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key

# Gemini — obter em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_gemini_api_key

# Resend — obter em: https://resend.com/api-keys
RESEND_API_KEY=sua_resend_api_key

# Email remetente (verificado no Resend)
EMAIL_FROM=dons@seudominio.com.br

# Email do admin (recebe notificações + cópia dos resultados)
ADMIN_EMAIL=marcoandre@gmail.com

# URL pública do app
APP_URL=https://dons-espirituais.vercel.app
